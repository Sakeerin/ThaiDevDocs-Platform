# ─── Algolia DocSearch ─────────────────────────────────────────────────────
# Apply for free DocSearch at https://docsearch.algolia.com/
# Leave blank to fall back to the built-in Orama search.
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=thaidevdocs

# ─── Giscus Comments ───────────────────────────────────────────────────────
# Generate at https://giscus.app/
NEXT_PUBLIC_GISCUS_REPO=thaidevdocs/thaidevdocs
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# ─── Plausible Analytics ───────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=thaidevdocs.com

# ─── Auth (NextAuth / Better Auth) ─────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Laravel API ───────────────────────────────────────────────────────────
API_URL=http://localhost:8000

# ─── LemonSqueezy ──────────────────────────────────────────────────────────
LEMON_SQUEEZY_STORE_ID=
